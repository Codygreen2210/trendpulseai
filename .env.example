# ═══════════════════════════════════════════════════════════════
#  TrendPulseAI — Environment Variables Template
#
#  Copy these variables into Vercel Dashboard:
#  Settings → Environment Variables → Add
#
#  DO NOT commit actual secrets to git!
# ═══════════════════════════════════════════════════════════════

# ─── ANTHROPIC (Claude AI) ────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── CLERK (User Authentication) ──────────────────────────────
# Get from: dashboard.clerk.com → API Keys
# The VITE_ prefix means it's exposed to the browser (publishable key is safe to expose)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── STRIPE (Payments) ────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...

# Get from: dashboard.stripe.com → Products → [your product] → Pricing section
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Get from: dashboard.stripe.com → Developers → Webhooks (AFTER deploy)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── APP URL ──────────────────────────────────────────────────
# Your live Vercel URL or custom domain
# Update this AFTER first deploy
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
